# Shelly Add-on Temperature Debug — example environment file
#
# Usage: cp env.example .env  → edit the values → docker compose up -d
# This file is the ONLY place you configure the app; the docker-compose file
# stays untouched. NEVER commit your real .env: it contains device passwords
# and the access token.

# ---- access control (REQUIRED) ------------------------------------------
# Generate a long random value:
#   openssl rand -hex 24
# Leaving it EXPLICITLY EMPTY (DEBUG_TOKEN=) disables authentication — only
# do that when your reverse proxy handles auth for this path.
DEBUG_TOKEN=change-me-to-a-long-random-value

# Optional: enables provisioning new DS18B20 sensors from the page (scan the
# add-on's 1-Wire bus, name + attach new probes; the Shelly reboots briefly
# to activate them). Pick a DIFFERENT long random value than DEBUG_TOKEN and
# share it only with people who may add sensors. Unset/empty = provisioning
# disabled (the API does not exist).
#PROVISION_PASSPHRASE=

# ---- Shelly devices (at least SHELLY_1_HOST is REQUIRED) ----------------
# Numbering is contiguous, starting at 1. http:// is assumed if no scheme.
SHELLY_1_HOST=192.168.1.50
SHELLY_1_NAME=Pool
#SHELLY_1_PASSWORD=per-device-password-if-different
#SHELLY_1_USER=admin

#SHELLY_2_HOST=shelly-garden.lan
#SHELLY_2_NAME=Garden
#SHELLY_2_PASSWORD=

# Fallback admin password used for every device without its own password.
# Leave empty if your Shellys have authentication disabled.
SHELLY_PASSWORD=

# ---- server (optional, defaults shown) ----------------------------------
#BASE_PATH=/debug                  # path prefix ("/" for root)
#PORT=8080                         # listen port INSIDE the container — must
#                                  # match the right side of "ports:" in the
#                                  # compose file, so best leave it at 8080
#HISTORY_MAX_MB=16                 # total in-memory history budget (MB), shared by all sensors
#BACKGROUND_POLL_SECONDS=0         # >0: server polls the Shellys itself; history and
#                                  # the live page fill without anyone clicking
#                                  # (0 = off; 60 is a good value to start with)
#QUERY_TIMEOUT_SECONDS=5           # per-device query timeout
#QUERY_MIN_INTERVAL_SECONDS=2      # rate limit between real device queries
#AUTO_REFRESH_SECONDS=30           # page auto-refresh interval
#AUTO_REFRESH_DEFAULT=false        # "true" starts auto-refresh enabled for new browsers
#METRICS_ENABLED=false             # "true" exposes Prometheus {BASE_PATH}/metrics
