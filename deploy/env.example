# Shelly Add-on Temperature Debug — example environment file
#
# Usage: cp env.example .env  → edit the values → docker compose up -d
# NEVER commit your real .env: it contains device passwords and the token.

# ---- access control (REQUIRED) ------------------------------------------
# Generate a long random value:
#   openssl rand -hex 24
# Leaving it EXPLICITLY EMPTY (DEBUG_TOKEN=) disables authentication — only
# do that when your reverse proxy handles auth for this path.
DEBUG_TOKEN=change-me-to-a-long-random-value

# ---- Shelly devices (at least SHELLY_1_HOST is REQUIRED) ----------------
# Numbering is contiguous, starting at 1. http:// is assumed if no scheme.
SHELLY_1_HOST=192.168.1.50
SHELLY_1_NAME=Pool
#SHELLY_1_PASSWORD=per-device-password-if-different
#SHELLY_1_USER=admin

#SHELLY_2_HOST=shelly-garden.lan
#SHELLY_2_NAME=Garden
#SHELLY_2_PASSWORD=

# Fallback admin password used for every device without its own password.
# Leave empty if your Shellys have authentication disabled.
SHELLY_PASSWORD=

# ---- server (optional, defaults shown) ----------------------------------
#BASE_PATH=/debug
#PORT=8080
#HISTORY_MAX_MB=16
#BACKGROUND_POLL_SECONDS=0
#QUERY_TIMEOUT_SECONDS=5
#QUERY_MIN_INTERVAL_SECONDS=2
#AUTO_REFRESH_SECONDS=30
#AUTO_REFRESH_DEFAULT=false
#METRICS_ENABLED=false
